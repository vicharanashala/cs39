# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to frontend/.env and adjust values for your environment.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
# Leave unset (or empty) for local development — Vite will proxy /api to VITE_API_PROXY_TARGET.
# Set to a full URL only when the frontend is deployed separately from the backend.
# VITE_API_URL=https://your-api-host.com/api

# Vite dev-server proxy target — all /api requests are forwarded here during development.
VITE_API_PROXY_TARGET=http://localhost:5000

# Socket.IO server origin.
# Defaults to VITE_API_PROXY_TARGET if not set (safe for local dev where both run on the same host).
# Override when your Socket.IO server is on a different host or port.
# VITE_SOCKET_URL=https://your-socketio-host.com

# Backend and frontend ports (used by Config.js for informational purposes).
# Change only if you run the servers on non-default ports.
VITE_BACKEND_PORT=5000
VITE_FRONTEND_PORT=5173

# Set to true only in local development to show quick-fill demo login buttons.
# Must be false (or unset) in production.
VITE_ENABLE_DEMO_LOGIN=false

# Set only when you need to bind the Vite dev server to your local network (LAN testing).
# VITE_DEV_HOST=0.0.0.0
