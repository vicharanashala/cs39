# Leave VITE_API_URL unset for local development so Vite proxies `/api`.
# Set it only when a deployed frontend calls a separately hosted backend.
# VITE_API_URL=https://your-api-host/api
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_ENABLE_DEMO_LOGIN=false
# Set only when local network testing is required.
VITE_DEV_HOST=localhost
